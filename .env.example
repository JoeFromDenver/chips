# Firebase Web Client Configuration Template
# Copy this file to a new file named '.env' and fill in your project credentials.
# After filling it out, run 'npm run build' and push to GitHub so that
# all guests are automatically synchronized to your database!

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
